<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_radar_inference_tree" model="ir.ui.view">
        <field name="name">radar.inference.tree</field>
        <field name="model">radar.inference</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="model_id"/>
                <field name="sample_id"/>
                <field name="prediction" widget="badge"
                       decoration-danger="prediction == 'uav'"
                       decoration-success="prediction == 'non_uav'"/>
                <field name="confidence" widget="float" digits="[6,4]"/>
                <field name="ground_truth"/>
                <field name="is_correct" widget="boolean"/>
                <field name="latency_ms"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_radar_inference_form" model="ir.ui.view">
        <field name="name">radar.inference.form</field>
        <field name="model">radar.inference</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_run_inference" string="執行推論" type="object"
                            class="btn-primary"
                            invisible="prediction"/>
                    <button name="action_load_spectrogram" string="載入頻譜圖" type="object"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="推論設定">
                            <field name="model_id"/>
                            <field name="sample_id"/>
                        </group>
                        <group string="推論結果">
                            <field name="prediction"/>
                            <field name="confidence" widget="float" digits="[6,4]"/>
                            <field name="ground_truth"/>
                            <field name="is_correct"/>
                            <field name="latency_ms"/>
                        </group>
                    </group>
                    <group string="頻譜圖" invisible="not spectrogram_img">
                        <field name="spectrogram_img" widget="image"
                               options="{'size': [600, 400]}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action: 推論紀錄列表 -->
    <record id="action_inference_list" model="ir.actions.act_window">
        <field name="name">推論紀錄</field>
        <field name="res_model">radar.inference</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                尚無推論紀錄
            </p>
            <p>選擇已啟用的模型與樣本 ID，執行即時推論。</p>
        </field>
    </record>

    <!-- Action: 新增推論 -->
    <record id="action_inference_new" model="ir.actions.act_window">
        <field name="name">新增推論</field>
        <field name="res_model">radar.inference</field>
        <field name="view_mode">form</field>
    </record>
</odoo>
