<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_radar_model_tree" model="ir.ui.view">
        <field name="name">radar.model.tree</field>
        <field name="model">radar.model</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="model_type"/>
                <field name="experiment_id"/>
                <field name="accuracy" widget="float" digits="[6,4]"/>
                <field name="eer" widget="float" digits="[6,4]"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_radar_model_form" model="ir.ui.view">
        <field name="name">radar.model.form</field>
        <field name="model">radar.model</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="啟用此模型" type="object"
                            class="btn-primary"
                            invisible="is_active"/>
                    <button name="action_deactivate" string="停用" type="object"
                            invisible="not is_active"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_activate" icon="fa-check-circle"
                                invisible="is_active">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">未啟用</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_deactivate" icon="fa-power-off"
                                invisible="not is_active">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text text-success">啟用中</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="模型資訊">
                            <field name="model_type"/>
                            <field name="experiment_id"/>
                            <field name="file_path"/>
                        </group>
                        <group string="效能指標">
                            <field name="accuracy"/>
                            <field name="eer"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_model_list" model="ir.actions.act_window">
        <field name="name">已訓練模型</field>
        <field name="res_model">radar.model</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                尚無已訓練模型
            </p>
            <p>完成訓練實驗後，模型會自動出現在此處。</p>
        </field>
    </record>
</odoo>
