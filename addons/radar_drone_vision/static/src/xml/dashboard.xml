<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="radar_drone_vision.Dashboard">
        <div class="o_action radar-dashboard" style="overflow-y: auto; max-height: calc(100vh - 50px); background: #0f172a; padding: 24px;">
            <style>
                .radar-dashboard { color: #e2e8f0; }
                .radar-dashboard h1 { color: #fff; font-size: 1.8rem; font-weight: 700; margin-bottom: 24px; }
                .radar-dashboard .accent { color: #4ade80; }
                .dash-card {
                    background: #1e293b;
                    border: 1px solid #334155;
                    border-radius: 12px;
                    padding: 24px;
                    margin-bottom: 16px;
                    cursor: pointer;
                    transition: transform 0.2s, border-color 0.2s;
                }
                .dash-card:hover { transform: translateY(-2px); border-color: #4ade80; }
                .dash-card .number { font-size: 2.5rem; font-weight: 700; color: #4ade80; }
                .dash-card .label { color: #94a3b8; font-size: 0.9rem; }
                .dash-card .sub { color: #64748b; font-size: 0.8rem; margin-top: 4px; }
                .dash-table { width: 100%; }
                .dash-table th { color: #94a3b8; font-weight: 500; padding: 8px 12px; border-bottom: 1px solid #334155; font-size: 0.85rem; }
                .dash-table td { color: #e2e8f0; padding: 8px 12px; border-bottom: 1px solid #1e293b; font-size: 0.9rem; }
                .badge-uav { background: #dc2626; color: #fff; padding: 2px 10px; border-radius: 12px; font-size: 0.8rem; }
                .badge-non-uav { background: #16a34a; color: #fff; padding: 2px 10px; border-radius: 12px; font-size: 0.8rem; }
                .badge-correct { color: #4ade80; }
                .badge-wrong { color: #f87171; }
                .btn-refresh {
                    background: #334155; color: #e2e8f0; border: none; padding: 8px 16px;
                    border-radius: 8px; cursor: pointer; font-size: 0.9rem;
                }
                .btn-refresh:hover { background: #475569; }
            </style>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1>雷達 AI 平台 <span class="accent">戰情室</span></h1>
                <button class="btn-refresh" t-on-click="refreshData">&#x21BB; 重新整理</button>
            </div>

            <!-- 統計卡片 -->
            <div class="row">
                <div class="col-md-2" t-on-click="openDatasets">
                    <div class="dash-card">
                        <div class="number" t-out="state.datasets"/>
                        <div class="label">資料集</div>
                        <div class="sub"><t t-out="state.datasets_ready"/> 個已就緒</div>
                    </div>
                </div>
                <div class="col-md-2" t-on-click="openExperiments">
                    <div class="dash-card">
                        <div class="number" t-out="state.experiments"/>
                        <div class="label">訓練實驗</div>
                        <div class="sub"><t t-out="state.experiments_trained"/> 個已完成</div>
                    </div>
                </div>
                <div class="col-md-2" t-on-click="openModels">
                    <div class="dash-card">
                        <div class="number" t-out="state.models"/>
                        <div class="label">已訓練模型</div>
                        <div class="sub"><t t-out="state.models_active"/> 個啟用中</div>
                    </div>
                </div>
                <div class="col-md-2" t-on-click="openInferences">
                    <div class="dash-card">
                        <div class="number" t-out="state.inferences"/>
                        <div class="label">推論紀錄</div>
                        <div class="sub">正確率 <t t-out="accuracyRate"/></div>
                    </div>
                </div>
                <div class="col-md-2" t-on-click="openHardware">
                    <div class="dash-card">
                        <div class="number" t-out="state.hardware"/>
                        <div class="label">硬體裝置</div>
                        <div class="sub"><t t-out="state.hardware_connected"/> 個已連線</div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="dash-card">
                        <div class="number accent" t-out="accuracyRate"/>
                        <div class="label">整體正確率</div>
                        <div class="sub"><t t-out="state.inferences_correct"/>/<t t-out="state.inferences"/></div>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <!-- 近期實驗 -->
                <div class="col-md-6">
                    <div class="dash-card" style="cursor:default;">
                        <h5 style="color:#fff;margin-bottom:16px;">近期已完成實驗</h5>
                        <t t-if="state.recent_experiments.length">
                            <table class="dash-table">
                                <thead>
                                    <tr>
                                        <th>實驗名稱</th>
                                        <th>類型</th>
                                        <th>準確率</th>
                                        <th>EER</th>
                                        <th>F1</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.recent_experiments" t-as="exp" t-key="exp.id">
                                        <tr>
                                            <td t-out="exp.name"/>
                                            <td t-out="exp.model_type"/>
                                            <td t-out="exp.accuracy ? exp.accuracy.toFixed(4) : '-'"/>
                                            <td t-out="exp.eer ? exp.eer.toFixed(4) : '-'"/>
                                            <td t-out="exp.f1_score ? exp.f1_score.toFixed(4) : '-'"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <p style="color:#64748b;">尚無已完成實驗</p>
                        </t>
                    </div>
                </div>

                <!-- 近期推論 -->
                <div class="col-md-6">
                    <div class="dash-card" style="cursor:default;">
                        <h5 style="color:#fff;margin-bottom:16px;">近期推論紀錄</h5>
                        <t t-if="state.recent_inferences.length">
                            <table class="dash-table">
                                <thead>
                                    <tr>
                                        <th>編號</th>
                                        <th>預測</th>
                                        <th>信心</th>
                                        <th>正確</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.recent_inferences" t-as="inf" t-key="inf.id">
                                        <tr>
                                            <td t-out="inf.name"/>
                                            <td>
                                                <span t-if="inf.prediction === 'uav'" class="badge-uav">UAV</span>
                                                <span t-elif="inf.prediction === 'non_uav'" class="badge-non-uav">非 UAV</span>
                                                <span t-else="">-</span>
                                            </td>
                                            <td t-out="inf.confidence ? (inf.confidence * 100).toFixed(1) + '%' : '-'"/>
                                            <td>
                                                <span t-if="inf.is_correct" class="badge-correct">&#x2714;</span>
                                                <span t-elif="inf.prediction" class="badge-wrong">&#x2718;</span>
                                                <span t-else="">-</span>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <p style="color:#64748b;">尚無推論紀錄</p>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
